# Discovery DJ backend environment (all optional — app runs with none set).

# --- Data ---
# deezer (default, real data) | mock (offline hand-curated library)
DATA_SOURCE=deezer

# --- CORS ---
# Comma-separated origins allowed to call the API (add your Vercel domain in prod).
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# --- LLM (why-lines + genre adjacency) ---
# Set ONE key to enable real AI reasoning. Without any key the app uses
# deterministic template fallbacks (fully functional, no setup required).
# Precedence if several are set: Anthropic > Groq > OpenAI.
# ANTHROPIC_API_KEY=sk-ant-...
# GROQ_API_KEY=gsk_...
# OPENAI_API_KEY=sk-...

# Optional overrides:
# LLM_MODEL=claude-opus-4-8        # or e.g. llama-3.3-70b-versatile (Groq), gpt-4o-mini
# LLM_BASE_URL=                    # custom OpenAI-compatible endpoint
# LLM_TEMPERATURE=0.7
# LLM_MAX_TOKENS=60
